# Supabase (project settings > API)
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_PUBLISHABLE_KEY=sua_chave_publica
SUPABASE_SERVICE_ROLE_KEY=sua_chave_secreta_service_role
VITE_SUPABASE_PROJECT_ID=seu_project_id
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sua_chave_publica

# Endereco HTTPS onde o aplicativo estiver publicado
APP_ORIGIN=https://seu-dominio.com.br

# Mercado Pago (Suas integracoes > Credenciais e Webhooks)
MP_ENV=sandbox
MP_PLATFORM_ACCESS_TOKEN=seu_access_token_de_teste
MP_WEBHOOK_SECRET=sua_assinatura_secreta_de_webhook
